# MongoDB connection string (e.g. MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/elderly_events

# Secret used to sign JWTs (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Optional
PORT=4000
JWT_EXPIRES_IN=7d
# Comma separated list of allowed origins, or * for all
CLIENT_ORIGIN=*

# Twilio (Phase 2 - SMS invitations). Optional: if these are not set, the
# backend runs in SIMULATION mode and logs SMS messages instead of sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Point your Twilio number's "A MESSAGE COMES IN" webhook to:
#   https://<your-backend-host>/api/twilio/webhook  (HTTP POST)
